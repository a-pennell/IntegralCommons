---
// GovernanceLoopDiagram — Issue lifecycle with side inputs/outputs.
// Source: docs/commonground-prd.md §"Core Conceptual Model" + §"Functional Requirements"

const W = 820;
const H = 360;

// Node geometry — pill-shaped status nodes, left-to-right
const nodeY = 200;
const nodeH = 38;
const nodeW = 118;
const gap = 40;
const startX = 30;

const nodes = [
  { id: 'open',      label: 'Open' },
  { id: 'exploring', label: 'Exploring' },
  { id: 'decided',   label: 'Decided' },
  { id: 'reopened',  label: 'Reopened' },
  { id: 'archived',  label: 'Archived' },
].map((n, i) => ({
  ...n,
  x: startX + i * (nodeW + gap),
  y: nodeY,
  w: nodeW,
  h: nodeH,
  cx: startX + i * (nodeW + gap) + nodeW / 2,
}));

const openNode      = nodes[0];
const exploringNode = nodes[1];
const decidedNode   = nodes[2];
const reopenedNode  = nodes[3];
const archivedNode  = nodes[4];

// Arrow endpoints between consecutive nodes
const arrowsForward = [
  { from: openNode,      to: exploringNode, hasGate: false },
  { from: exploringNode, to: decidedNode,   hasGate: true  }, // Decision Record gate
  { from: decidedNode,   to: reopenedNode,  hasGate: false },
  { from: reopenedNode,  to: archivedNode,  hasGate: false },
];

// Gate (Decision Record) — sits ON the exploring -> decided arrow
const gateArrow = arrowsForward[1];
const gateW = 100;
const gateH = 30;
const gateCx = (gateArrow.from.x + gateArrow.from.w + gateArrow.to.x) / 2;
const gateCy = nodeY + nodeH / 2;
const gateX = gateCx - gateW / 2;
const gateY = gateCy - gateH / 2;
---

<figure class="loop-diagram" role="img" aria-labelledby="loop-title loop-desc">
  <p id="loop-title" class="sr-only">CommonGround governance loop</p>
  <p id="loop-desc" class="sr-only">
    An Issue flows through five statuses from left to right: Open, Exploring, Decided, Reopened, Archived.
    Perspectives — Values, Risk, Equity, Feasibility, Relational, Temporal — feed into Exploring from above.
    A Decision Record is required to advance from Exploring to Decided and sits on that arrow as a gate.
    Reopened can loop back to Exploring. Civic Memory runs along the bottom as a timeline logging every transition.
  </p>

  <svg
    class="loop-svg"
    viewBox={`0 0 ${W} ${H}`}
    preserveAspectRatio="xMidYMid meet"
    aria-hidden="true"
  >
    <defs>
      <marker id="loop-arrow" viewBox="0 0 10 10" refX="9" refY="5"
              markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 Z" fill="var(--muted)" />
      </marker>
    </defs>

    <!-- Perspectives cluster (feeds INTO Exploring from above) -->
    <g class="persp" transform={`translate(${exploringNode.cx - 125}, 30)`}>
      <text x="125" y="14" text-anchor="middle" class="svg-label">Perspectives</text>
      <g fill="none" stroke="var(--ink)" stroke-width="0.5">
        <rect x="0"   y="28" width="36" height="30" />
        <rect x="42"  y="28" width="36" height="30" />
        <rect x="84"  y="28" width="36" height="30" />
        <rect x="126" y="28" width="36" height="30" />
        <rect x="168" y="28" width="36" height="30" />
        <rect x="210" y="28" width="36" height="30" />
      </g>
      <g class="svg-persp-letter">
        <text x="18"  y="48" text-anchor="middle">V</text>
        <text x="60"  y="48" text-anchor="middle">R</text>
        <text x="102" y="48" text-anchor="middle">E</text>
        <text x="144" y="48" text-anchor="middle">F</text>
        <text x="186" y="48" text-anchor="middle">R</text>
        <text x="228" y="48" text-anchor="middle">T</text>
      </g>
      <text x="125" y="78" text-anchor="middle" class="svg-persp-legend">
        Values · Risk · Equity · Feasibility · Relational · Temporal
      </text>
      <!-- feeder line from cluster down to Exploring -->
      <line x1="125" y1="88" x2="125" y2="138" stroke="var(--rule)" stroke-width="0.5"
            marker-end="url(#loop-arrow)" />
    </g>

    <!-- Forward arrows -->
    <g fill="none" stroke="var(--muted)" stroke-width="0.5">
      {arrowsForward.map((a) => {
        const x1 = a.from.x + a.from.w + 2;
        const x2 = a.to.x - 2;
        // If this is the gate arrow, split it around the gate box
        if (a.hasGate) {
          return (
            <>
              <line x1={x1} y1={nodeY + nodeH / 2} x2={gateX - 2} y2={nodeY + nodeH / 2} />
              <line x1={gateX + gateW + 2} y1={nodeY + nodeH / 2} x2={x2} y2={nodeY + nodeH / 2}
                    marker-end="url(#loop-arrow)" />
            </>
          );
        }
        return (
          <line x1={x1} y1={nodeY + nodeH / 2} x2={x2} y2={nodeY + nodeH / 2}
                marker-end="url(#loop-arrow)" />
        );
      })}
    </g>

    <!-- Reopened loopback to Exploring (curved arrow above nodes) -->
    <g fill="none" stroke="var(--muted)" stroke-width="0.5">
      <path
        d={`M ${reopenedNode.cx} ${nodeY}
            C ${reopenedNode.cx} ${nodeY - 60},
              ${exploringNode.cx} ${nodeY - 60},
              ${exploringNode.cx + 20} ${nodeY}`}
        marker-end="url(#loop-arrow)"
      />
      <text x={(reopenedNode.cx + exploringNode.cx) / 2} y={nodeY - 66}
            text-anchor="middle" class="svg-loop-label">loop back</text>
    </g>

    <!-- Status nodes (pill-shaped via rx=nodeH/2; rx here is a geometry primitive, not a stylistic rounded corner) -->
    <g>
      {nodes.map((n) => (
        <>
          <rect x={n.x} y={n.y} width={n.w} height={n.h}
                rx={n.h / 2} ry={n.h / 2}
                fill="var(--paper)" stroke="var(--ink)" stroke-width="0.5" />
          <text x={n.cx} y={n.y + n.h / 2 + 4} text-anchor="middle" class="svg-node-label">
            {n.label.toUpperCase()}
          </text>
        </>
      ))}
    </g>

    <!-- Decision Record gate — the single accent element in the diagram -->
    <g>
      <rect x={gateX} y={gateY} width={gateW} height={gateH}
            fill="var(--paper)" stroke="var(--accent)" stroke-width="0.75" />
      <text x={gateCx} y={gateY + gateH / 2 + 3} text-anchor="middle" class="svg-gate-label">
        Decision Record
      </text>
      <text x={gateCx} y={gateY - 8} text-anchor="middle" class="svg-gate-req">
        REQUIRED TO ADVANCE
      </text>
    </g>

    <!-- Civic Memory — horizontal timeline along the bottom -->
    <g>
      <line x1="30" y1="320" x2={W - 30} y2="320" stroke="var(--rule)" stroke-width="0.5" />
      <g fill="var(--muted)">
        {nodes.map((n) => (
          <circle cx={n.cx} cy="320" r="1.5" />
        ))}
      </g>
      <text x={W / 2} y="340" text-anchor="middle" class="svg-memory-label">
        civic memory · timeline · every transition logged
      </text>
    </g>
  </svg>

  <!-- Responsive fallback: vertical flow for narrow viewports -->
  <ol class="loop-fallback">
    <li>
      <span class="label loop-f-step">Open</span>
      <span class="loop-f-note">Issue created</span>
    </li>
    <li>
      <span class="label loop-f-step">Exploring</span>
      <span class="loop-f-note">Perspectives gather — Values · Risk · Equity · Feasibility · Relational · Temporal</span>
    </li>
    <li class="gate">
      <span class="loop-f-gate label">Decision Record</span>
      <span class="loop-f-req label">required to advance</span>
    </li>
    <li>
      <span class="label loop-f-step">Decided</span>
      <span class="loop-f-note">Rationale and review date captured</span>
    </li>
    <li class="branch">
      <span class="label loop-f-step">Reopened</span>
      <span class="loop-f-note">Branches back to Exploring</span>
    </li>
    <li>
      <span class="label loop-f-step">Archived</span>
      <span class="loop-f-note">Closed; record preserved in civic memory</span>
    </li>
  </ol>
  <p class="loop-memory-note">civic memory · timeline · every transition logged</p>
</figure>

<style>
  .loop-diagram {
    margin: 0;
    padding: 24px;
    border: 0.5px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
  }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .loop-svg {
    display: block;
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    height: auto;
  }

  .svg-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    fill: var(--muted);
  }
  .svg-persp-letter {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--ink);
  }
  .svg-persp-legend {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 12px;
    fill: var(--muted);
  }
  .svg-node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    fill: var(--ink);
  }
  .svg-gate-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    fill: var(--ink);
  }
  .svg-gate-req {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    fill: var(--accent);
  }
  .svg-loop-label {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 10px;
    fill: var(--muted);
  }
  .svg-memory-label {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 11px;
    fill: var(--muted);
  }

  /* Fallback — vertical flow */
  .loop-fallback {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .loop-fallback li {
    border-top: 0.5px solid var(--rule);
    padding: 14px 4px;
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 12px;
    align-items: baseline;
  }
  .loop-fallback li:last-child { border-bottom: 0.5px solid var(--rule); }
  .loop-fallback li.gate {
    border-top: 0.5px solid var(--accent);
  }
  .loop-f-step { color: var(--ink); }
  .loop-f-note {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--muted);
  }
  .loop-f-gate {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink);
  }
  .loop-f-req { color: var(--accent); font-size: 10px; }
  .loop-fallback li.branch { border-top-style: dashed; }
  .loop-memory-note {
    display: none;
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 11px;
    color: var(--muted);
    margin: 16px 0 0;
    text-align: center;
  }

  @media (max-width: 820px) {
    .loop-svg { display: none; }
    .loop-fallback { display: block; }
    .loop-memory-note { display: block; }
  }
</style>
