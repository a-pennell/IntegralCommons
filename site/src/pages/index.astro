---
import { getEntry, render } from 'astro:content';
import Article from '../layouts/Article.astro';
import LayerDiagram from '../components/LayerDiagram.astro';
import EcosystemStackDiagram from '../components/EcosystemStackDiagram.astro';
const entry = await getEntry('source', 'icos_overview');
if (!entry) throw new Error('icos_overview not found');
const { Content } = await render(entry);
---
<Article title="CommonGround" sectionLabel="§ Integral Commons OS" logoSrc="/commonground.svg">
  <div class="premise-intro">
    <p>Systems ignoring human development create fragmentation.</p>
    <p>Centralized power leads to capture.</p>
    <p>Democracy without structure becomes noise.</p>
    <p>Structure without participation becomes domination.</p>
  </div>

  <Content />

  <div class="design-goal">
    <p class="label" style="margin-bottom: 16px;">Enabling systems that are</p>
    <p>Adaptive.</p>
    <p>Participatory.</p>
    <p>Resistant to capture.</p>
    <p>Developmentally supportive.</p>
  </div>

  <hr class="rule" />
  <h2>The five scales</h2>
  <LayerDiagram variant="static" />
  <hr class="rule" />
  <h2>The ecosystem</h2>
  <EcosystemStackDiagram />

  <hr class="rule" />
  <h2>Documentation Map</h2>
  <table>
    <thead><tr><th>Document</th><th>What it covers</th></tr></thead>
    <tbody>
      <tr><td>icos-architecture.md</td><td>Full layer model, holonic principle, interoperability, shared principles</td></tr>
      <tr><td>lcos-prd.md</td><td>Layer 1: Local Commons — neighborhood coordination</td></tr>
      <tr><td>flow-engine-prd.md</td><td>Layer 2: Flow Engine (Synapse, Equip, Kindred) — resource flow</td></tr>
      <tr><td>eil-prd.md</td><td>Layer 3: Ecological Impact Layer — ecological awareness infrastructure</td></tr>
      <tr><td>cip-prd.md</td><td>Layer 4: Care Integration Platform — relational care</td></tr>
      <tr><td>commonground-prd.md</td><td>Layer 5: CommonGround — group-scale governance</td></tr>
      <tr><td>mcs-prd.md</td><td>Layer 5: Modular Civic Stack — civic/municipal governance</td></tr>
      <tr><td>intelligence-layer-prd.md</td><td>Layer 6: Intelligence Layer — cross-layer synthesis and legibility</td></tr>
      <tr><td>governance-layer-relationships.md</td><td>How Local Commons governance, CommonGround, and MCS relate</td></tr>
      <tr><td>manifesto.md</td><td>Principles and commitments</td></tr>
    </tbody>
  </table>
</Article>

<style is:global>
  /* suppress markdown title and version/date — shown in article-head instead */
  .article-body > h2:first-of-type { display: none; }
  .article-body > p:first-of-type { display: none; }
  .article-body > hr:first-of-type { display: none; }

  .premise-intro {
    margin-bottom: 64px;
    padding-bottom: 48px;
    border-bottom: 0.5px solid var(--rule);
  }
  .premise-intro p {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.3;
    margin: 0 0 8px;
    color: var(--ink);
  }
  .premise-intro p:last-child { margin-bottom: 0; }

  .design-goal {
    margin-top: 64px;
    padding: 40px 0;
    border-top: 0.5px solid var(--rule);
  }
  .design-goal p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.4;
    margin: 0 0 4px;
    color: var(--ink);
  }
  .design-goal .label { font-style: normal; color: var(--muted); }
</style>
