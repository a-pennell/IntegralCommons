---
interface Props {
  title: string;
}
const { title } = Astro.props;
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <script is:inline>document.documentElement.classList.add('js');</script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <link rel="preload" href="/fonts/SourceSerif4-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <meta name="description" content="CommonGround — a premise, three commitments, one operating system." />
</head>
<body class="narrative-body">
  <a class="skip-link" href="#scene-01">Skip to main content</a>
  <header class="narrative-header">
    <div class="narrative-header-inner">
      <a class="narrative-mark" href="/">CommonGround</a>
      <nav class="narrative-nav label">
        <a href="/manifesto">Manifesto</a>
        <a href="/constitution">Constitution</a>
        <a href="/protocol">Protocol</a>
        <a href="/overview">Overview</a>
        <a href="/docs">Docs</a>
      </nav>
      <span class="narrative-edition label">Vol. I · Spring 2026</span>
    </div>
  </header>
  <main id="scene-01" class="narrative">
    <slot />
  </main>

  <script>
    import { initScroll, installBaselineReveal } from '../lib/scroll';
    import { mountHeroEntrance } from '../lib/hero';
    initScroll();
    installBaselineReveal();
    mountHeroEntrance();
  </script>
</body>
</html>

<style is:global>
  .narrative-body { background: var(--paper); }
  .narrative { display: block; }

  .skip-link {
    position: absolute; left: -9999px;
    background: var(--ink); color: var(--paper);
    padding: 8px 16px; font-family: var(--font-mono); font-size: 12px;
  }
  .skip-link:focus { left: 16px; top: 16px; z-index: 100; }

  /* 12-col grid used by scenes */
  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: var(--gutter);
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 48px;
  }
  .col-center { grid-column: 4 / 10; }
  .col-margin { grid-column: 1 / 4; }
  .col-wide   { grid-column: 2 / 12; }

  .scene {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 0;
    position: relative;
  }
  .scene .section-no { color: var(--muted); }

  .stanza p {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1.25;
    margin: 0 0 28px;
  }

  .act-label {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--fs-label-tracking);
    text-transform: uppercase;
    color: var(--muted);
  }

  .narrative-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 20px 48px;
    border-bottom: 0.5px solid var(--rule);
  }
  .narrative-header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    gap: 32px;
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .narrative-mark {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .narrative-nav {
    display: flex;
    gap: 24px;
    justify-self: center;
  }
  .narrative-nav a {
    color: var(--muted);
    text-decoration: none;
  }
  .narrative-nav a:hover { color: var(--ink); }
  .narrative-edition {
    justify-self: end;
    color: var(--muted);
    white-space: nowrap;
  }
  @media (max-width: 800px) {
    .narrative-header { padding: 16px 24px; }
    .narrative-header-inner { grid-template-columns: 1fr auto; gap: 16px; }
    .narrative-nav { display: none; }
  }

  html.js [data-hero-wordmark],
  html.js [data-hero-tagline],
  html.js [data-hero-rung],
  html.js [data-hero-scroll] {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    html.js [data-hero-wordmark],
    html.js [data-hero-tagline],
    html.js [data-hero-rung],
    html.js [data-hero-scroll] {
      opacity: 1;
    }
  }
</style>
