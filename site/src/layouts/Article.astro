---
interface Props {
  title: string;
  sectionLabel?: string;
  logoSrc?: string;
}
const { title, sectionLabel, logoSrc } = Astro.props;
const appUrl = 'https://app.cmmngrnd.us';
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title} &mdash; CommonGround</title>
  <link rel="preload" href="/fonts/LibreBaskerville-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/PublicSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
</head>
<body>
  <header class="site-header">
    <a class="wordmark" href="/">
      <img src="/commonground.svg" alt="CommonGround" class="wordmark-logo" />
    </a>
    <nav class="site-nav label">
      <a href="/">Overview</a>
      <a href="/manifesto">Manifesto</a>
      <a href="/patterns">Patterns</a>
      <a href="/docs">Docs</a>
    </nav>
    <div class="site-header-end label">
      <span class="site-edition">Vol. I &middot; Spring 2026</span>
      <a class="site-app-link" href={appUrl}>Open App &rarr;</a>
    </div>
    <button class="nav-toggle label" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open navigation">
      <span class="nav-toggle-icon" aria-hidden="true">&#9776;</span>
    </button>
  </header>
  <nav id="mobile-nav" class="mobile-nav" aria-hidden="true" aria-label="Mobile navigation">
    <a href="/">Overview</a>
    <a href="/manifesto">Manifesto</a>
    <a href="/patterns">Patterns</a>
    <a href="/docs">Docs</a>
    <a href={appUrl} class="mobile-nav-app">Open App</a>
  </nav>

  <main class="article">
    <div class="article-head">
      {sectionLabel && <p class="label">{sectionLabel}</p>}
      {logoSrc
        ? <h1><img src={logoSrc} alt={title} class="article-logo" /></h1>
        : <h1>{title}</h1>
      }
    </div>
    <article class="article-body">
      <slot />
    </article>
  </main>

  <footer class="site-footer label">
    <span>CommonGround &middot; built on ICOS</span>
    <a href="/docs">All source documents</a>
  </footer>

  <script>
    const toggle = document.querySelector('.nav-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    function closeNav() {
      if (!toggle) return;
      toggle.setAttribute('aria-expanded', 'false');
      const icon = toggle.querySelector('.nav-toggle-icon');
      if (icon) icon.textContent = '☰';
      if (mobileNav) { mobileNav.setAttribute('aria-hidden', 'true'); mobileNav.classList.remove('is-open'); }
    }
    if (toggle) {
      toggle.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        if (open) { closeNav(); } else {
          toggle.setAttribute('aria-expanded', 'true');
          const icon = toggle.querySelector('.nav-toggle-icon');
          if (icon) icon.textContent = '✕';
          if (mobileNav) { mobileNav.setAttribute('aria-hidden', 'false'); mobileNav.classList.add('is-open'); }
        }
      });
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeNav(); });
    if (mobileNav) mobileNav.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));
  </script>
</body>
</html>

<style is:global>
  .site-header {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 24px 48px;
    border-bottom: 0.5px solid var(--rule);
  }
  .wordmark {
    text-decoration: none;
    display: flex;
    align-items: center;
  }
  .wordmark-logo {
    height: 16px;
    width: auto;
    display: block;
  }
  .site-nav { display: flex; gap: 24px; }
  .site-nav a { text-decoration: none; color: var(--muted); }
  .site-nav a:hover { color: var(--ink); }
  .site-header-end {
    display: flex;
    align-items: baseline;
    gap: 20px;
  }
  .site-edition { color: var(--muted); white-space: nowrap; }
  .site-app-link { color: var(--muted); text-decoration: none; white-space: nowrap; }
  .site-app-link:hover { color: var(--ink); }

  /* Hamburger toggle */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    color: var(--ink);
    font-size: 18px;
    line-height: 1;
  }

  /* Mobile nav drawer */
  .mobile-nav {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 50;
    background: var(--paper);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }
  .mobile-nav.is-open { display: flex; }
  .mobile-nav a {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .mobile-nav a:hover { color: var(--muted); }
  .mobile-nav-app {
    margin-top: 16px;
    font-family: var(--font-mono) !important;
    font-size: var(--fs-label) !important;
    letter-spacing: var(--fs-label-tracking) !important;
    text-transform: uppercase;
    color: var(--muted) !important;
  }

  @media (max-width: 800px) {
    .site-header { padding: 16px 24px; }
    .site-nav { display: none; }
    .site-header-end { display: none; }
    .nav-toggle { display: block; }
    .article { padding: 80px 24px; }
  }

  .article {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 120px 48px;
  }
  .article-head { margin-bottom: 80px; }
  .article-head .label { margin-bottom: 12px; }
  .article-head h1 {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.08;
    max-width: 18ch;
  }
  .article-logo {
    width: min(100%, 902px);
    height: auto;
    display: block;
  }
  .article-body { margin: 0; max-width: 100%; }
  .article-body h2 { font-size: var(--fs-h2); margin: 64px 0 16px; }
  .article-body h3 { font-size: var(--fs-h3); margin: 40px 0 12px; }
  .article-body p { margin: 0 0 24px; }
  .article-body ul, .article-body ol { padding-left: 24px; margin: 0 0 24px; }
  .article-body li { margin-bottom: 6px; }
  .article-body blockquote {
    margin: 32px 0; padding-left: 24px;
    border-left: 2px solid var(--accent);
    font-style: italic; color: var(--ink);
  }
  .article-body code {
    font-family: var(--font-mono); font-size: 0.9em;
    background: #f0ece4; padding: 1px 6px; border-radius: 2px;
  }
  .article-body pre {
    font-family: var(--font-mono); font-size: 14px;
    background: #f0ece4; padding: 16px 20px; border-radius: 4px;
    overflow-x: auto;
  }
  .article-body pre code { background: none; padding: 0; }

  .article-body table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.95em;
  }
  .article-body th, .article-body td {
    text-align: left;
    padding: 10px 16px 10px 0;
    border-bottom: 0.5px solid var(--rule);
    vertical-align: top;
  }
  .article-body th {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--fs-label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
  }
  .article-body td:first-child,
  .article-body th:first-child {
    white-space: nowrap;
    width: 1%;
    padding-right: 32px;
  }

  .site-footer {
    display: flex; justify-content: space-between;
    padding: 40px 48px;
    border-top: 0.5px solid var(--rule);
    color: var(--muted);
  }
  .site-footer a { color: var(--muted); text-decoration-color: var(--rule); }
</style>
