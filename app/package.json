{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "description": "CommonGround — structured deliberation for small-group governance",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/server/jobs/worker.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:constitutional": "vitest run --config vitest.constitutional.config.ts --passWithNoTests",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@commonground/contracts": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "^15",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "pino": "^10.3.1",
    "react": "^19",
    "react-dom": "^19",
    "rehype": "^13.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "ulid": "^3.0.2",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^2.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^15.11.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "testcontainers": "^11.14.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^2.1.9"
  }
}
