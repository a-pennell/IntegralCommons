# CommonGround environment variables.
# Copy to `.env` (or `.env.local`) for local development; provide via your
# orchestrator (docker-compose, Fly.io secrets, etc.) in production.
#
# Every variable needed to boot the app is listed here. If a variable is
# undocumented below but required by the app, that's a bug — file an issue.

# --- Required ---

# PostgreSQL connection string. Must point at a Postgres 16+ instance.
# Docker-compose self-host uses: postgres://commonground:commonground@postgres:5432/commonground
DATABASE_URL=postgres://commonground:commonground@localhost:5432/commonground

# Secret used to sign session cookies. Must be at least 32 bytes of randomness.
# Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-please-use-openssl-rand-base64-48

# --- Email adapter (NFR-008 self-host requirement) ---

# Selects the outbound email implementation.
# Values: `mailhog` | `smtp` | `resend`
EMAIL_ADAPTER=mailhog

# Mailhog adapter (docker-compose dev).
MAILHOG_HOST=localhost
MAILHOG_PORT=1025

# SMTP adapter (self-hosters with their own SMTP provider).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="CommonGround <noreply@example.com>"
# SMTP_SECURE=false

# Resend adapter (hosted reference only).
# RESEND_API_KEY=
# RESEND_FROM="CommonGround <noreply@example.com>"

# --- Storage adapter (for export bundles) ---

# Values: `local` | `s3`
STORAGE_ADAPTER=local
# STORAGE_LOCAL_PATH=/var/lib/commonground/exports

# S3-compatible storage (only used when STORAGE_ADAPTER=s3).
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=commonground-exports
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# --- Observability (optional) ---

# OpenTelemetry OTLP endpoint. Leave unset to disable tracing entirely.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-api-key
# OTEL_SERVICE_NAME=commonground

# Pino log level. Default: info. Values: trace | debug | info | warn | error | fatal.
# LOG_LEVEL=info

# --- Next.js ---

# Port the Next.js server listens on.
PORT=3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
