{
  "name": "icos",
  "private": true,
  "version": "0.0.0",
  "description": "ICOS monorepo — marketing site (site/) and CommonGround application (app/)",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "site:dev": "pnpm --filter site dev",
    "site:build": "pnpm --filter site build",
    "app:dev": "pnpm --filter app dev",
    "app:build": "pnpm --filter app build",
    "app:test": "pnpm --filter app test",
    "app:typecheck": "pnpm --filter app typecheck"
  }
}
